---
import BaseLayout from "../layouts/BaseLayout.astro";

// On simule une liste de documents (plus tard, cela pourrait venir d'un CMS ou d'un fichier JSON)
const documents = [
  { title: "Code Pénal Togolais (Version simplifiée)", category: "Lois", date: "2023", size: "1.2 MB" },
  { title: "Guide de l'Accès au Droit au Togo", category: "Guides", date: "2024", size: "850 KB" },
  { title: "Rapport Annuel CARIJ 2023", category: "Rapports", date: "2023", size: "2.4 MB" },
  { title: "Décret sur la réforme institutionnelle", category: "Textes officiels", date: "2022", size: "500 KB" },
  { title: "Manuel de réinsertion des ex-détenus", category: "Guides", date: "2024", size: "1.5 MB" },
];
---

<BaseLayout title="Documentation & Textes de Loi - CARIJ">
  
  <section class="bg-primary py-16 text-white px-6">
    <div class="container mx-auto text-center">
      <h1 class="text-3xl font-bold mb-6 text-white">Centre de Documentation</h1>
      <p class="mb-8 opacity-90 max-w-xl mx-auto text-sm">
        Consultez et téléchargez les textes de lois vulgarisés, les guides pratiques et les rapports d'activités du comité.
      </p>
      
      <div class="max-w-2xl mx-auto flex gap-2 bg-white p-2 rounded-lg shadow-2xl">
        <input 
          type="text" 
          placeholder="Rechercher un document (ex: Code pénal...)" 
          class="flex-1 px-4 py-2 text-slate-800 outline-none text-sm"
        />
        <button class="bg-secondary text-white px-6 py-2 rounded font-bold text-sm hover:brightness-110 transition">
          Rechercher
        </button>
      </div>
    </div>
  </section>

  <section class="py-16 container mx-auto px-6">
    <div class="flex flex-col lg:flex-row gap-12">
      
      <aside class="w-full lg:w-64 flex-shrink-0">
        <h3 class="font-bold text-slate-900 mb-4 border-b pb-2">Catégories</h3>
        <ul class="space-y-2">
          {['Tous les documents', 'Lois & Décrets', 'Guides Pratiques', 'Rapports d\'activités', 'Sensibilisation'].map(cat => (
            <li>
              <button class="text-sm text-slate-600 hover:text-primary hover:font-bold transition-all w-full text-left py-1">
                {cat}
              </button>
            </li>
          ))}
        </ul>
      </aside>

      <div class="flex-1">
        <div class="grid sm:grid-cols-2 gap-6">
          {documents.map(doc => (
            <div class="border border-slate-200 p-6 rounded-xl hover:border-primary/30 hover:shadow-lg transition-all group bg-white">
              <div class="flex justify-between items-start mb-4">
                <span class="text-[10px] font-bold uppercase tracking-widest bg-slate-100 text-slate-500 px-2 py-1 rounded">
                  {doc.category}
                </span>
                <span class="text-primary group-hover:scale-110 transition-transform text-2xl">📄</span>
              </div>
              <h4 class="font-bold text-slate-900 mb-2 leading-tight group-hover:text-primary transition-colors">
                {doc.title}
              </h4>
              <div class="flex justify-between items-center mt-6">
                <div class="text-[11px] text-slate-400">
                  <span class="mr-3">📅 {doc.date}</span>
                  <span>💾 {doc.size}</span>
                </div>
                <button class="text-secondary font-bold text-xs flex items-center gap-1 hover:underline">
                  Télécharger ⬇️
                </button>
              </div>
            </div>
          ))}
        </div>
        
        <div class="mt-12 flex justify-center gap-2">
          <button class="w-8 h-8 flex items-center justify-center rounded border border-primary bg-primary text-white text-xs">1</button>
          <button class="w-8 h-8 flex items-center justify-center rounded border border-slate-200 text-slate-600 text-xs hover:bg-slate-50">2</button>
        </div>
      </div>

    </div>
  </section>

</BaseLayout>