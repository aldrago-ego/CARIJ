---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="Accueil - CARIJ">
  
  <section class="bg-primary relative overflow-hidden flex items-center min-h-[500px]">
    <div class="container mx-auto px-6 grid md:grid-cols-2 gap-8 items-center py-12">
      <div class="text-white z-10">
        <h1 class="text-3xl md:text-5xl font-bold mb-6 leading-[1.1]">
          Agir ensemble pour une justice équitable et des institutions fortes
        </h1>
        <p class="text-slate-200 text-sm md:text-base max-w-lg mb-8 leading-relaxed opacity-90">
          Le CARIJ œuvre au Togo pour promouvoir l'accès au droit, renforcer les capacités et accompagner les personnes vulnérables vers la réinsertion.
        </p>
        <div class="flex gap-4">
          <a href="/domaines" class="bg-secondary px-6 py-3 rounded font-bold text-sm">Découvrir nos actions</a>
          <a href="/organisation" class="border border-white/50 px-6 py-3 rounded font-bold text-sm hover:bg-white/10 transition">En savoir plus sur le CARIJ</a>
        </div>
      </div>
      
      <div class="hidden md:block relative">
        <div class="rounded-3xl overflow-hidden shadow-2xl border-4 border-white/10">
          <div class="bg-slate-800 h-80 flex items-center justify-center text-white italic">
            [Image de la balance de justice et loi]
          </div>
        </div>
      </div>
    </div>
  </section>

  <div class="container mx-auto px-6 -mt-10 relative z-20">
    <div class="bg-white rounded-xl shadow-lg py-8 px-4 grid grid-cols-2 md:grid-cols-4 border border-slate-100">
      <div class="flex flex-col items-center border-r border-slate-100">
        <span class="text-2xl font-bold text-primary">2016</span>
        <span class="text-[10px] text-slate-500 uppercase font-bold text-center">Année de création</span>
      </div>
      <div class="flex flex-col items-center border-r border-slate-100">
        <span class="text-2xl font-bold text-primary">1000+</span>
        <span class="text-[10px] text-slate-500 uppercase font-bold text-center">Personnes accompagnées</span>
      </div>
      <div class="flex flex-col items-center border-r border-slate-100">
        <span class="text-2xl font-bold text-primary">50+</span>
        <span class="text-[10px] text-slate-500 uppercase font-bold text-center">Textes juridiques vulgarisés</span>
      </div>
      <div class="flex flex-col items-center">
        <span class="text-2xl font-bold text-primary">10+</span>
        <span class="text-[10px] text-slate-500 uppercase font-bold text-center">Partenaires engagés</span>
      </div>
    </div>
  </div>

  <section class="py-16 bg-slate-50">
    <div class="container mx-auto px-6">
      <div class="bg-white p-8 rounded-2xl shadow-sm border border-slate-200 flex flex-col md:flex-row items-center gap-10">
        <div class="flex items-center gap-4 md:w-1/3">
           <div class="bg-primary text-white p-4 rounded-xl text-2xl font-bold leading-none italic uppercase tracking-tighter">
            ⚖️
           </div>
           <div>
             <h4 class="font-bold text-primary">Vulgarisation des textes</h4>
             <p class="text-xs text-slate-500">Recherchez et consultez les textes juridiques vulgarisés pour mieux connaître vos droits.</p>
           </div>
        </div>

        <div class="flex flex-1 w-full gap-2">
          <input type="text" placeholder="Rechercher un texte juridique..." class="w-full border border-slate-200 px-4 py-3 rounded text-sm focus:ring-1 focus:ring-primary outline-none" />
          <button class="bg-primary text-white px-8 py-3 rounded text-sm font-bold">Rechercher</button>
        </div>

        <div class="hidden md:block">
           <div class="w-24 h-24 bg-primary/10 rounded-full flex items-center justify-center">
             📖
           </div>
        </div>
      </div>
    </div>
  </section>

</BaseLayout>