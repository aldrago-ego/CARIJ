---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="Contact & Assistance - CARIJ">
  <section class="bg-slate-100 py-16 border-b border-slate-200">
    <div class="container mx-auto px-6">
      <h1 class="text-3xl font-bold text-primary mb-4">Contact & Assistance</h1>
      <p class="text-slate-600 max-w-2xl">Vous avez besoin d'une orientation juridique ou vous souhaitez collaborer avec nous ? Utilisez le formulaire ci-dessous ou nos coordonnées directes.</p>
    </div>
  </section>

  <section class="py-20 container mx-auto px-6">
    <div class="grid lg:grid-cols-3 gap-12">
      
      <div class="space-y-8">
        <div>
          <h3 class="font-bold text-lg text-slate-900 mb-4 italic">Nos bureaux</h3>
          <div class="space-y-4">
            <div class="flex gap-4">
              <span class="text-secondary text-xl">📍</span>
              <p class="text-sm text-slate-600 leading-relaxed">
                Quartier Avédji, non loin du carrefour,<br>
                Lomé, République Togolaise
              </p>
            </div>
            <div class="flex gap-4">
              <span class="text-secondary text-xl">📞</span>
              <p class="text-sm text-slate-600">
                +228 90 00 00 00 / 22 00 00 00
              </p>
            </div>
            <div class="flex gap-4">
              <span class="text-secondary text-xl">✉️</span>
              <p class="text-sm text-slate-600 font-bold">
                contact@carij.tg
              </p>
            </div>
          </div>
        </div>

        <div class="bg-primary/5 p-6 rounded-2xl border border-primary/10">
          <h4 class="font-bold text-primary mb-3 text-sm uppercase">Heures d'écoute</h4>
          <ul class="text-xs space-y-2 text-slate-700">
            <li class="flex justify-between border-b border-white/50 pb-1"><span>Lundi - Vendredi</span> <span>08:00 - 17:30</span></li>
            <li class="flex justify-between"><span>Samedi (Urgences)</span> <span>09:00 - 12:00</span></li>
          </ul>
        </div>
      </div>

      <div class="lg:col-span-2 bg-white rounded-3xl shadow-sm border border-slate-100 p-8 md:p-10">
        <form class="space-y-6">
          <div class="grid md:grid-cols-2 gap-6">
            <div class="space-y-2">
              <label for="name" class="text-xs font-bold uppercase text-slate-500 tracking-wider">Nom Complet</label>
              <input type="text" id="name" placeholder="Ex: Jean Koffi" class="w-full bg-slate-50 border border-slate-200 rounded-lg px-4 py-3 text-sm focus:ring-1 focus:ring-secondary outline-none transition" />
            </div>
            <div class="space-y-2">
              <label for="email" class="text-xs font-bold uppercase text-slate-500 tracking-wider">Adresse Email</label>
              <input type="email" id="email" placeholder="votre@email.com" class="w-full bg-slate-50 border border-slate-200 rounded-lg px-4 py-3 text-sm focus:ring-1 focus:ring-secondary outline-none transition" />
            </div>
          </div>

          <div class="space-y-2">
            <label for="subject" class="text-xs font-bold uppercase text-slate-500 tracking-wider">Objet du message</label>
            <select id="subject" class="w-full bg-slate-50 border border-slate-200 rounded-lg px-4 py-3 text-sm focus:ring-1 focus:ring-secondary outline-none appearance-none">
              <option>Demande d'assistance juridique</option>
              <option>Demande de partenariat</option>
              <option>Information sur la réinsertion</option>
              <option>Autre</option>
            </select>
          </div>

          <div class="space-y-2">
            <label for="message" class="text-xs font-bold uppercase text-slate-500 tracking-wider">Votre message</label>
            <textarea id="message" rows="5" placeholder="Décrivez brièvement votre situation..." class="w-full bg-slate-50 border border-slate-200 rounded-lg px-4 py-3 text-sm focus:ring-1 focus:ring-secondary outline-none transition"></textarea>
          </div>

          <button type="submit" class="w-full md:w-auto bg-primary text-white px-10 py-4 rounded-xl font-bold text-sm uppercase tracking-widest hover:bg-slate-800 transition-all shadow-lg">
            Envoyer le message
          </button>
        </form>
      </div>

    </div>
  </section>

  <section class="h-96 w-full bg-slate-100 relative overflow-hidden">
    <div class="absolute inset-0 grayscale opacity-70 hover:grayscale-0 transition-all duration-500">
      <iframe 
        src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3966.521260322283!2d1.1734274!3d6.201304!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x102159439461ed13%3A0x576aa59ca3b415c8!2sBNCE-TOGO!5e0!3m2!1sfr!2stg!4v1714147200000!5m2!1sfr!2stg" 
        class="w-full h-full border-0" 
        allowfullscreen="" 
        loading="lazy" 
        referrerpolicy="no-referrer-when-downgrade">
      </iframe>
    </div>
    
    <div class="absolute bottom-10 left-10 bg-white p-4 rounded-xl shadow-2xl border border-slate-100 z-30 hidden md:block">
      <p class="text-[10px] font-bold text-primary uppercase mb-1">Siège Social</p>
      <p class="text-xs font-medium text-slate-700">4e rue après l'Église Catholique Avédji</p>
      <a href="https://www.google.com/maps/dir//6.201304,1.1734274" target="_blank" class="text-secondary text-[10px] font-bold underline mt-2 inline-block">
        Calculer l'itinéraire
      </a>
    </div>
  </section>
</BaseLayout>