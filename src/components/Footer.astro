---
const currentYear = new Date().getFullYear();
---

<footer class="bg-slate-900 text-slate-300 py-12 mt-20">
  <div class="container mx-auto px-6 grid md:grid-cols-3 gap-10">
    <div>
      <h3 class="text-white text-xl font-bold mb-4">CARIJ</h3>
      <p class="text-sm leading-relaxed">
        Centre d'Appui à la Réforme Institutionnelle et à la Justice. 
        OEuvrer pour une justice équitable et accessible au Togo.
      </p>
    </div>
    
    <div>
      <h4 class="text-white font-semibold mb-4">Liens rapides</h4>
      <ul class="space-y-2 text-sm">
        <li><a href="/domaines" class="hover:text-secondary">Nos domaines d'action</a></li>
        <li><a href="/organisation" class="hover:text-secondary">Notre équipe</a></li>
        <li><a href="/contact" class="hover:text-secondary">Assistance juridique</a></li>
      </ul>
    </div>

    <div>
      <h4 class="text-white font-semibold mb-4">Localisation</h4>
      <p class="text-sm">Lomé, Togo</p>
      <p class="text-sm mt-2 font-bold text-secondary">Contact@carij.org</p>
    </div>
  </div>
  
  <div class="border-t border-slate-800 mt-10 pt-6 text-center text-xs">
    <p>&copy; {currentYear} CARIJ - Tous droits réservés.</p>
  </div>
</footer>