---
// On récupère le chemin de l'URL actuelle
const { pathname } = Astro.url;

const navItems = [
  { name: 'Accueil', href: '/' },
  { name: 'L\'Organisation', href: '/organisation' },
  { name: 'Domaines d\'Intervention', href: '/domaines' },
  { name: 'Documentation', href: '/documentation' },
  { name: 'Contact', href: '/contact' },
];

// Fonction utilitaire pour vérifier si le lien est actif
// On gère le cas du "/" final qui peut varier selon l'environnement
const isActive = (href: string) => {
  if (href === '/') return pathname === '/' || pathname === '';
  return pathname.startsWith(href);
};
---

<header class="w-full">
  <div class="bg-primary text-white text-[11px] py-2 border-b border-white/10">
    <div class="container mx-auto px-6 flex justify-between items-center">
      <div class="flex gap-4">
        <span class="flex items-center gap-1"><i class="opacity-80">📍</i> Avédji, Lomé - Togo</span>
        <span class="flex items-center gap-1"><i class="opacity-80">✉️</i> contact@carij.tg</span>
        <span class="flex items-center gap-1"><i class="opacity-80">📞</i> +228 90 00 00 00</span>
      </div>
      <div class="flex gap-4 items-center">
        <span>Suivez-nous :</span>
        <div class="flex gap-2 text-sm">
          <a href="#" class="hover:text-secondary transition-colors">f</a>
          <a href="#" class="hover:text-secondary transition-colors">t</a>
          <a href="#" class="hover:text-secondary transition-colors">in</a>
        </div>
      </div>
    </div>
  </div>

  <nav class="bg-white py-4 shadow-sm sticky top-0 z-50">
    <div class="container mx-auto px-6 flex justify-between items-center">
      <a href="/" class="flex items-center gap-3 group">
        <div class="w-12 h-12 bg-primary rounded-full flex items-center justify-center text-white font-bold p-1 group-hover:scale-105 transition-transform">
           ⚖️
        </div>
        <div>
          <h1 class="text-xl font-bold text-primary leading-none uppercase tracking-tighter">CARIJ</h1>
          <p class="text-[9px] text-slate-500 uppercase leading-tight font-medium">Comité d'Appui aux Réformes<br>Institutionnelles et Juridictionnelles</p>
        </div>
      </a>

      <div class="hidden lg:flex items-center gap-6">
        {navItems.map(item => {
          const active = isActive(item.href);
          return (
            <a 
              href={item.href} 
              class:list={[
                "text-sm font-semibold py-1 transition-all border-b-2",
                // Si la page est active : texte vert et souligné en orange/gold
                active ? "text-primary border-secondary" : "text-slate-700 border-transparent hover:text-primary hover:border-primary/30"
              ]}
            >
              {item.name}
            </a>
          );
        })}
        
        <a href="/contact" class="bg-secondary text-white px-5 py-2 rounded text-sm font-bold uppercase tracking-wide hover:shadow-lg hover:-translate-y-0.5 transition-all active:translate-y-0">
          Demande d'assistance
        </a>
      </div>
    </div>
  </nav>
</header>